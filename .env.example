# ─── Walrus Memory ─────────────────────────────────────────────
# Auto-filled by `pnpm setup:account` (creates a free testnet account).
# Do NOT commit the real .env.local — the delegate key is a secret.
MEMWAL_NETWORK=testnet
MEMWAL_SERVER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_ACCOUNT_ID=0x...            # MemWalAccount object id (on-chain)
MEMWAL_PRIVATE_KEY=...             # Ed25519 delegate key (hex) — SERVER ONLY
SUI_PRIVATE_KEY=suiprivkey1...     # funding wallet, reused across setup re-runs

# ─── Model (GLM 5.2, OpenAI-compatible) ────────────────────────
GLM_API_KEY=                       # from https://z.ai  (required for chat + profile)
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2
